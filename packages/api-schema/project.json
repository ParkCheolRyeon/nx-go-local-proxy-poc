{
  "name": "api-schema",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/api-schema/src",
  "targets": {
    "gen": {
      "executor": "nx:run-commands",
      "dependsOn": ["dp-back:gen"],
      "options": {
        "command": "openapi-typescript openapi.yaml -o src/types.ts",
        "cwd": "packages/api-schema"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.json",
        "{workspaceRoot}/tsconfig.base.json"
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -b",
        "cwd": "packages/api-schema"
      }
    }
  }
}
