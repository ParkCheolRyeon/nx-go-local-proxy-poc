{
  "name": "igallery-db",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/igallery-db",
  "targets": {
    "sqlc:gen": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/sqlc.yml",
        "{projectRoot}/queries/**/*.sql",
        "{projectRoot}/migrations/**/*.sql"
      ],
      "outputs": ["{projectRoot}/db"],
      "options": {
        "command": "sqlc generate",
        "cwd": "packages/igallery-db"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/**/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum"
      ],
      "options": {
        "command": "go vet ./...",
        "cwd": "packages/igallery-db"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/**/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum"
      ],
      "options": {
        "command": "go vet ./...",
        "cwd": "packages/igallery-db"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/**/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum"
      ],
      "options": {
        "command": "go test ./...",
        "cwd": "packages/igallery-db"
      }
    }
  }
}
